LLM_PROVIDER="groq"

GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-20b"
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"

# Optional shared secret required from the Meet audio capture extension.
MEETINGOPS_EXTENSION_TOKEN=""

# Optional alternative provider
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Google Workspace OAuth and Pub/Sub configuration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"
GOOGLE_PUBSUB_TOPIC="projects/your-project/topics/meetingops-events"
GOOGLE_WEBHOOK_SECRET=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# Optional persistent directory for hosted deployments (for example, /data on Railway).
MEETINGOPS_DATA_DIR=""
