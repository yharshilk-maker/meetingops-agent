{
  "manifest_version": 3,
  "name": "MeetingOps Meet Agent",
  "version": "0.2.0",
  "description": "Captures Google Meet tab audio and dispatches the MeetingOps agent to join the call.",
  "permissions": ["activeTab", "offscreen", "storage", "tabCapture"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://meetingops-production.up.railway.app/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MeetingOps Meet Agent"
  }
}
